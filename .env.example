# CodeAtlas configuration template.
#
# Copy this file to `.env` at the repository root and put real secrets there.
# Never commit `.env`; it is git-ignored.

# ---- OpenAI -------------------------------------------------------------
OPENAI_API_KEY=                 # required: your OpenAI API key
OPENAI_MODEL=gpt-5-nano         # budget-safe answering model
OPENAI_EMBEDDING_MODEL=text-embedding-3-small  # low-cost embeddings for retrieval
OPENAI_ENRICHMENT_MODEL=gpt-5-nano             # only used when optional LLM stages are enabled

# ---- Embeddings backend -------------------------------------------------
# "openai" or "local". Use "openai" for the normal API-backed setup.
EMBEDDING_BACKEND=openai
EMBEDDING_MODEL=                # only used when EMBEDDING_BACKEND=local

# ---- Optional OpenAI-powered stages ------------------------------------
# Keep these false for a small API budget.
ENABLE_INDEX_SUMMARIES=false    # avoids one LLM call per chunk during indexing
ENABLE_QUERY_EXPANSION=false    # avoids one extra LLM call per chat question
ENABLE_LLM_RERANK=false         # avoids LLM reranking calls during retrieval
RETRIEVAL_TOP_K=5               # chunks sent to the answering model
RETRIEVAL_CANDIDATE_K=8         # candidates fetched from each retrieval backend

# ---- Vector store and data ---------------------------------------------
CHROMA_PERSIST_DIR=./data/chroma
DATA_DIR=./data
RESET_INDEX_ON_START=false      # set true to wipe the local index every backend start

# ---- Frontend to backend ------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
