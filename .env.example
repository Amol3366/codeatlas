# CodeAtlas configuration — template. PROJECT-GLOBAL: lives at the repo root
# (codeatlas/.env), NOT inside backend/ and NOT inside .venv/. It is a plain
# secrets file, entirely separate from the .venv/ virtual-environment directory.
#
# Copy to `.env` at the repo root (`cp .env.example .env`) and fill in real
# values. The backend loads it via pydantic-settings (see CLAUDE.md §11).
# `.env` is git-ignored and MUST NEVER be committed. This template holds
# placeholders only — no real secrets, no hardcoded model names in source.

# ---- OpenAI (required) --------------------------------------------------
OPENAI_API_KEY=                 # required — your OpenAI API key
OPENAI_MODEL=                   # answering model, e.g. a current GPT-4-class model
OPENAI_EMBEDDING_MODEL=         # e.g. text-embedding-3-small
OPENAI_ENRICHMENT_MODEL=        # cheaper model for summaries/rerank, e.g. a mini GPT model

# ---- Embeddings backend -------------------------------------------------
# "openai" (default) or "local" (sentence-transformers, needs the `local` extra / PyTorch)
EMBEDDING_BACKEND=openai
EMBEDDING_MODEL=                # only used when EMBEDDING_BACKEND=local (e.g. a BAAI/bge-* model)

# ---- Optional OpenAI-powered stages (cost/latency knobs) ----------------
ENABLE_INDEX_SUMMARIES=true     # default true  -> summarize + embed each chunk for better recall
ENABLE_QUERY_EXPANSION=false    # default false -> expand/HyDE the query before retrieval
ENABLE_LLM_RERANK=false         # default false -> rerank top-k with OpenAI

# ---- Vector store (Chroma) & data ---------------------------------------
CHROMA_PERSIST_DIR=./data/chroma   # on-disk path where the Chroma collection is persisted
DATA_DIR=./data                    # where the index / local DB lives

# ---- Frontend -> backend ------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000   # frontend reads this; do not hardcode in source
